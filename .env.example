# GitHub personal access token
# Required scopes: repo, codespace, delete_repo
GITHUB_TOKEN=ghp_your_token_here

# GitHub account/org where repos will be forked into
GITHUB_FORK_OWNER=your-github-username

# Google Gemini API key
GEMINI_API_KEY=your_gemini_api_key_here

# Storage directory for JSON scan files
DATA_DIR=./data

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Pipeline timeouts (seconds)
FORK_POLL_TIMEOUT=120
CODESPACE_READY_TIMEOUT=300
EXECUTION_TIMEOUT=180

# Mock mode: "full" (no external calls) | "no_codespace" | "off"
# Use "full" for CI/tests, "off" for real runs
SCANNER_MOCK_MODE=off
